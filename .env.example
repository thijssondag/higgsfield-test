# Copy values into Cursor Cloud Agent secrets (Dashboard → Cloud Agents → Secrets).
# Do not commit real credentials to this repo.

# Full JSON from ~/.config/higgsfield/credentials.json after `higgsfield auth login`.
# The cloud install script writes this to ~/.config/higgsfield/credentials.json.
HIGGSFIELD_CREDENTIALS_JSON=

# Optional override if credentials are stored at a custom path inside the VM.
# HIGGSFIELD_CREDENTIALS_PATH=/home/ubuntu/.config/higgsfield/credentials.json
